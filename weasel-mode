#!/bin/bash
# Switch Weasel ASCII mode via WeaselServer.exe
#   ascii  → English mode
#   nascii → native mode (中文/日本語/한국어...)
#
# Path: WEASEL_SERVER env var (required — no fallback)

case "${1:-}" in
  ascii)
    arg="/ascii"
    ;;
  nascii)
    arg="/nascii"
    ;;
  *)
    echo "Usage: weasel-mode {ascii|nascii}"
    exit 1
    ;;
esac

exe="${WEASEL_SERVER:-}"
if [ -z "$exe" ]; then
  exit 0
fi

powershell.exe -NoProfile -Command "& '$exe' $arg"
