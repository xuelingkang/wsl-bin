#!/bin/bash
# Switch Weasel ASCII mode via WeaselServer.exe
#   ascii  → English mode
#   nascii → native mode (中文/日本語/한국어...)

case "${1:-}" in
  ascii)
    arg="/ascii"
    ;;
  nascii)
    arg="/nascii"
    ;;
  *)
    echo "Usage: weasel-mode {ascii|nascii}"
    exit 1
    ;;
esac

powershell.exe -NoProfile -Command "& 'C:\Program Files\Rime\weasel-0.17.4\WeaselServer.exe' $arg"
