#!/bin/bash
# Switch Weasel ASCII mode via WeaselServer.exe
#   ascii  → English mode
#   nascii → native mode (中文/日本語/한국어...)

case "${1:-}" in
  ascii)
    arg="/ascii"
    ;;
  nascii)
    arg="/nascii"
    ;;
  *)
    echo "Usage: weasel-mode {ascii|nascii}"
    exit 1
    ;;
esac

powershell.exe -NoProfile -Command "
  \$exe = Get-ChildItem 'C:\Program Files\Rime' -Recurse -Filter 'WeaselServer.exe' |
          Sort-Object LastWriteTime -Descending |
          Select-Object -First 1 -ExpandProperty FullName
  if (-not \$exe) { exit 1 }
  & \$exe \$arg
"
