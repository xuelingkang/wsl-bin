#!/bin/bash
# Switch Weasel ASCII mode via WeaselServer.exe
#   ascii  → English mode
#   nascii → native mode (中文/日本語/한국어...)
#
# Path resolution order:
#   1. WEASEL_SERVER env var (strict — if set, use it as-is)
#   2. Registry via reg.exe (HKLM\Software\WOW6432Node\Rime\Weasel)

case "${1:-}" in
  ascii)
    arg="/ascii"
    ;;
  nascii)
    arg="/nascii"
    ;;
  *)
    echo "Usage: weasel-mode {ascii|nascii}"
    exit 1
    ;;
esac

powershell.exe -NoProfile -Command "
  \$exe = [Environment]::GetEnvironmentVariable('WEASEL_SERVER')
  if (-not \$exe) {
    \$root = reg query 'HKLM\Software\WOW6432Node\Rime\Weasel' /v WeaselRoot 2>\$null
    if (\$LASTEXITCODE -eq 0) {
      \$root = (\$root | Select-String 'REG_SZ\s+(.+)').Matches.Groups[1].Value
      \$name = reg query 'HKLM\Software\WOW6432Node\Rime\Weasel' /v ServerExecutable 2>\$null
      if (\$LASTEXITCODE -eq 0) {
        \$name = (\$name | Select-String 'REG_SZ\s+(.+)').Matches.Groups[1].Value
        \$exe = Join-Path \$root \$name
      }
    }
  }
  if (-not \$exe -or -not (Test-Path \$exe)) { exit 1 }
  & \$exe \$arg
"
