#!/bin/bash
# Switch Weasel ASCII mode via WeaselServer.exe
#   ascii  → English mode
#   nascii → native mode (中文/日本語/한국어...)
#
# Path resolution order:
#   1. WEASEL_SERVER env var (strict — if set, use it as-is)
#   2. Registry (HKLM\Software\WOW6432Node\Rime\Weasel)

case "${1:-}" in
  ascii)
    arg="/ascii"
    ;;
  nascii)
    arg="/nascii"
    ;;
  *)
    echo "Usage: weasel-mode {ascii|nascii}"
    exit 1
    ;;
esac

powershell.exe -NoProfile -Command "
  \$exe = [Environment]::GetEnvironmentVariable('WEASEL_SERVER')
  if (-not \$exe) {
    \$reg = Get-ItemProperty 'HKLM:\Software\WOW6432Node\Rime\Weasel' -ErrorAction SilentlyContinue
    if (\$reg -and \$reg.WeaselRoot -and \$reg.ServerExecutable) {
      \$exe = Join-Path \$reg.WeaselRoot \$reg.ServerExecutable
    }
  }
  if (-not \$exe -or -not (Test-Path \$exe)) { exit 1 }
  & \$exe \$arg
"
